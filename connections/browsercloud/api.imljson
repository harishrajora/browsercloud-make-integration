{
	"url": "https://api.lambdatest.com/automation/api/v1/sessions",
	"method": "GET",
	"qs": { "limit": 1 },
	"headers": {
		"Authorization": "Basic {{base64(parameters.username + ':' + parameters.accessKey)}}"
	},
	"response": {
		"error": { "message": "Invalid TestMu AI credentials ({{statusCode}})" }
	},
	"log": { "sanitize": ["request.headers.authorization"] }
}
