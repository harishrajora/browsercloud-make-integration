{
  "url": "/session/{{parameters.sessionId}}/screenshot",
  "method": "GET",
  "response": {
    "output": {
      "sessionId": "{{parameters.sessionId}}",
      "fileName": "screenshot.png",
      "data": "{{toBinary(body.value; 'base64')}}",
      "image": "{{body.value}}",
      "fullPage": false
    }
  }
}
